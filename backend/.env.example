# Get your key at https://aistudio.google.com/apikey
# Note: this is a Gemini API key, separate from any Google AI Pro/Ultra
# consumer subscription. It has its own free tier (no credit card needed).
GEMINI_API_KEY=your-gemini-api-key-here

# Model used to tailor resumes. gemini-2.5-flash is fast, capable, and
# free-tier eligible. Check https://ai.google.dev/gemini-api/docs/models
# if you want to try a different one (e.g. gemini-2.5-pro for higher quality).
GEMINI_MODEL=gemini-2.5-flash

# Port the backend server runs on
PORT=5050

# Frontend origin allowed to call this API (for CORS)
CLIENT_ORIGIN=http://localhost:5173
